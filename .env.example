# Cinelas Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# DATABASE
# ============================================
POSTGRES_USER=cinelas
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=cinelas

# ============================================
# TMDB API
# ============================================
TMDB_API_KEY=your_tmdb_api_key_here

# ============================================
# GOOGLE OAUTH
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ============================================
# HTTPS DEV CERT (Docker)
# ============================================
ASPNETCORE_HTTPS_PASSWORD=your_pfx_password_here

# ============================================
# PGADMIN (Development only)
# ============================================
PGADMIN_EMAIL=admin@cinelas.com
PGADMIN_PASSWORD=admin

# ============================================
# AZURE OPENAI (v2.0 AI Discovery)
# ============================================
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_TEMPERATURE=0.3
AZURE_OPENAI_MAX_TOKENS=1024
AZURE_OPENAI_SYSTEM_PROMPT_OVERRIDE=
